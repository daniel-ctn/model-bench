# PostgreSQL-compatible connection string (Neon, Supabase, or local Postgres).
# Neon example (use the *pooled* connection string):
#   postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/DB?sslmode=require
# Local example:
#   postgresql://postgres:postgres@localhost:5432/modelbench
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/modelbench"
