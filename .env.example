# PostgreSQL-compatible connection string (Neon, Supabase, or local Postgres).
# Neon example (use the *pooled* connection string):
#   postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/DB?sslmode=require
# Local example:
#   postgresql://postgres:postgres@localhost:5432/modelbench
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/modelbench"

# Auth (better-auth)
# Generate a secret: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
BETTER_AUTH_SECRET="change-me"
# Base URL of the app (used in reset-password links).
BETTER_AUTH_URL="http://localhost:3000"

# Email (optional). If RESEND_API_KEY is unset, password-reset links are logged
# to the server console instead of being emailed.
# RESEND_API_KEY=""
# EMAIL_FROM="ModelBench <onboarding@resend.dev>"
